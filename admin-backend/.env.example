# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit .env.

# Chuỗi kết nối MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/admin_seo

# Cổng chạy API
PORT=3000

# Origin được CORS cho phép (URL của SatWeb)
CLIENT_URL=http://localhost:5173

# Khóa ký JWT access token
JWT_SECRET=
# Khóa ký JWT refresh token (nên KHÁC JWT_SECRET)
JWT_REFRESH_SECRET=
# Thời hạn token (ví dụ 15m, 1h, 7d)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Khóa express-session
SESSION_SECRET_KEY=

# Tài khoản admin duy nhất để đăng nhập
APP_USERNAME=
APP_PASSWORD=

# Khóa OpenAI cho tính năng viết lại nội dung (utils/createVariations.js)
OPENAI_API_KEY=

# Base URL công khai của server (build URL ảnh tuyệt đối khi repost)
SERVER_URL=http://localhost:3000

# URL của frontend — dùng để dựng link xác thực trong email (deploy thì đổi sang domain thật)
FE_URL=http://localhost:5173

# Cấu hình gửi email chào mừng khi đăng ký (Nodemailer)
# Gmail: bật xác thực 2 bước rồi tạo "App Password" 16 ký tự, điền vào EMAIL_PASS.
# Bỏ trống EMAIL_USER/EMAIL_PASS thì hệ thống vẫn cho đăng ký nhưng KHÔNG gửi email.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=POSTA <no-reply@posta.vn>

# Google OAuth Client ID (Web). FE cần VITE_GOOGLE_CLIENT_ID cùng giá trị. Để trống = tắt.
GOOGLE_CLIENT_ID=
