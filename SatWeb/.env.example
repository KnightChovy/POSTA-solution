# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit .env.
# Vite chỉ expose biến có prefix VITE_ ra trình duyệt.

# Origin của admin-backend
VITE_API_BASE_URL=http://localhost:3000

# Key TinyMCE (cloud) — lấy ở TinyMCE dashboard, approve domain (localhost + domain Vercel)
VITE_TINYMCE_API_KEY=your-tinymce-api-key
